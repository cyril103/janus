class Tracker() {
    destructor {
        println("destroyed")
    }
}

val answer : int = 42
var requests : int = initialRequests()
private val message : string = "global"
private val tracker : Tracker = new Tracker()

def initialRequests() : int {
    return 10
}

def recordRequest() : Unit {
    requests = requests + 1
}

def main() : int {
    recordRequest()
    recordRequest()
    println(message)
    println(answer)
    println(requests)
    return 0
}
