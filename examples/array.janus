import std.array

def main() : int {
    val values : Array[int] = new Array[int](usize(1))
    values.push(10)
    values.push(20)
    values.push(12)
    values.set(usize(0), values.get(usize(0)) + values.pop())
    val result : int = values.get(usize(0)) + values.get(usize(1))
    delete values
    return result
}
