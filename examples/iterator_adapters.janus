import std.range

def main() : int {
    var total : int = 0

    for pair in range(1, 4).zip[int](range(10, 13)) {
        total = total + pair.left + pair.right
    }

    for indexed in range(5, 8).enumerate() {
        total = total + int(indexed.index) + indexed.value
    }

    for value in range(1, 4).flatMap[int](
        (item : int) => range(item, item + 2)
    ) {
        total = total + value
    }

    return total
}
