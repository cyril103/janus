import std.math

def main() : int {
    val width : usize = usize(84)
    val height : usize = usize(30)

    print("gcd: ")
    println(std.math.gcd(width, height))

    print("lcm: ")
    println(std.math.lcm(width, height))

    print("prime: ")
    println(std.math.is_prime(usize(97)))
    return 0
}
