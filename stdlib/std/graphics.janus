struct Vector2(val x : float, val y : float) {}

struct Rectangle(
val x : float,
val y : float,
val width : float,
val height : float
) {}

struct Color(private val packedValue : uint) {
    def packed() : uint {
        return packedValue
    }
}

class Camera2D(
var offsetX : float,
var offsetY : float,
var targetX : float,
var targetY : float,
var rotation : float,
var zoom : float
) {}

class Texture(private val handle : Ptr[byte]) {
    def isValid() : bool {
        return janus_graphics_texture_is_valid(handle)
    }

    def width() : int {
        return janus_graphics_texture_width(handle)
    }

    def height() : int {
        return janus_graphics_texture_height(handle)
    }

    def draw(x : int, y : int, tint : uint) : Unit {
        janus_graphics_draw_texture(handle, x, y, tint)
    }

    def drawAt(position : Vector2, tint : Color) : Unit {
        janus_graphics_draw_texture(
        handle,
        int(position.x),
        int(position.y),
        tint.packed()
        )
    }

    def drawPro(
    source : Rectangle,
    destination : Rectangle,
    origin : Vector2,
    rotation : float,
    tint : Color
    ) : Unit {
        janus_graphics_draw_texture_pro(
        handle,
        source.x,
        source.y,
        source.width,
        source.height,
        destination.x,
        destination.y,
        destination.width,
        destination.height,
        origin.x,
        origin.y,
        rotation,
        tint.packed()
        )
    }

    def drawFrame(
    frame : int,
    frameWidth : int,
    frameHeight : int,
    columns : int,
    position : Vector2,
    scale : float,
    rotation : float,
    flipX : bool,
    flipY : bool,
    tint : Color
    ) : Unit {
        val column : int = frame % columns
        val row : int = frame / columns
        var sourceWidth : float = float(frameWidth)
        var sourceHeight : float = float(frameHeight)
        if flipX {
            sourceWidth = -sourceWidth
        }
        if flipY {
            sourceHeight = -sourceHeight
        }
        janus_graphics_draw_texture_pro(
        handle,
        float(column * frameWidth),
        float(row * frameHeight),
        sourceWidth,
        sourceHeight,
        position.x,
        position.y,
        float(frameWidth) * scale,
        float(frameHeight) * scale,
        float(0.0),
        float(0.0),
        rotation,
        tint.packed()
        )
    }

    def setFilter(filter : TextureFilter) : Unit {
        janus_graphics_set_texture_filter(handle, int(filter))
    }

    destructor {
        janus_graphics_unload_texture(handle)
    }
}

class Font(private val handle : Ptr[byte]) {
    def isValid() : bool {
        return janus_graphics_font_is_valid(handle)
    }

    def draw(
    text : string,
    position : Vector2,
    fontSize : float,
    spacing : float,
    color : Color
    ) : Unit {
        janus_graphics_draw_text_font(
        handle,
        cstr(text),
        position.x,
        position.y,
        fontSize,
        spacing,
        color.packed()
        )
    }

    def measure(
    text : string,
    fontSize : float,
    spacing : float
    ) : Vector2 {
        return vector2(
        janus_graphics_measure_text_width(
        handle,
        cstr(text),
        fontSize,
        spacing
        ),
        janus_graphics_measure_text_height(
        handle,
        cstr(text),
        fontSize,
        spacing
        )
        )
    }

    destructor {
        janus_graphics_unload_font(handle)
    }
}

class SpriteAnimation(
val texture : Texture,
val frameWidth : int,
val frameHeight : int,
val columns : int,
val frameCount : int,
var currentFrame : int
) {
    def advance() : int {
        currentFrame = (currentFrame + 1) % frameCount
        return currentFrame
    }

    def reset() : Unit {
        currentFrame = 0
    }

    def draw(
    position : Vector2,
    scale : float,
    rotation : float,
    flipX : bool,
    flipY : bool,
    tint : Color
    ) : Unit {
        texture.drawFrame(
        currentFrame,
        frameWidth,
        frameHeight,
        columns,
        position,
        scale,
        rotation,
        flipX,
        flipY,
        tint
        )
    }
}

