    }

    def setPitch(pitch : float) : Unit {
        janus_graphics_set_music_pitch(handle, pitch)
    }

    def setPan(pan : float) : Unit {
        janus_graphics_set_music_pan(handle, pan)
    }

    destructor {
        janus_graphics_unload_music(handle)
    }
}

def rgba(red : ubyte, green : ubyte, blue : ubyte, alpha : ubyte) : uint {
    return janus_graphics_rgba(red, green, blue, alpha)
}

def vector2(x : float, y : float) : Vector2 {
    return new Vector2(x, y)
}

def rectangle(x : float, y : float, width : float, height : float) : Rectangle {
    return new Rectangle(x, y, width, height)
}

def colorRgba(
red : ubyte,
green : ubyte,
blue : ubyte,
alpha : ubyte
) : Color {
    return new Color(rgba(red, green, blue, alpha))
}

def colorRgb(red : ubyte, green : ubyte, blue : ubyte) : Color {
    return new Color(rgb(red, green, blue))
}

def rgb(red : ubyte, green : ubyte, blue : ubyte) : uint {
    return rgba(red, green, blue, 255)
}

def black() : uint {
    return rgb(0, 0, 0)
}

def white() : uint {
    return rgb(255, 255, 255)
}

def red() : uint {
    return rgb(230, 41, 55)
}

def green() : uint {
    return rgb(0, 228, 48)
}

def blue() : uint {
    return rgb(0, 121, 241)
}

