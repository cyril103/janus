def beginCamera(camera : Camera2D) : Unit {
    janus_graphics_begin_camera(
    camera.offsetX,
    camera.offsetY,
    camera.targetX,
    camera.targetY,
    camera.rotation,
    camera.zoom
    )
}

def endCamera() : Unit {
    janus_graphics_end_camera()
}

def screenToWorld(position : Vector2, camera : Camera2D) : Vector2 {
    return vector2(
    janus_graphics_screen_to_world_x(
    position.x,
    position.y,
    camera.offsetX,
    camera.offsetY,
    camera.targetX,
    camera.targetY,
    camera.rotation,
    camera.zoom
    ),
    janus_graphics_screen_to_world_y(
    position.x,
    position.y,
    camera.offsetX,
    camera.offsetY,
    camera.targetX,
    camera.targetY,
    camera.rotation,
    camera.zoom
    )
    )
}

def worldToScreen(position : Vector2, camera : Camera2D) : Vector2 {
    return vector2(
    janus_graphics_world_to_screen_x(
    position.x,
    position.y,
    camera.offsetX,
    camera.offsetY,
    camera.targetX,
    camera.targetY,
    camera.rotation,
    camera.zoom
    ),
    janus_graphics_world_to_screen_y(
    position.x,
    position.y,
    camera.offsetX,
    camera.offsetY,
    camera.targetX,
    camera.targetY,
    camera.rotation,
    camera.zoom
    )
    )
}

def clearBackground(color : uint) : Unit {
    janus_graphics_clear_background(color)
}

def clearColor(color : Color) : Unit {
    clearBackground(color.packed())
}

def drawPixel(x : int, y : int, color : uint) : Unit {
    janus_graphics_draw_pixel(x, y, color)
}

def drawPixelAt(position : Vector2, color : Color) : Unit {
    drawPixel(int(position.x), int(position.y), color.packed())
}

def drawLine(
startX : int,
startY : int,
endX : int,
endY : int,
color : uint
) : Unit {
    janus_graphics_draw_line(startX, startY, endX, endY, color)
}

def drawLineBetween(start : Vector2, end : Vector2, color : Color) : Unit {
    drawLine(
    int(start.x),
    int(start.y),
    int(end.x),
    int(end.y),
    color.packed()
    )
}

def drawCircle(
centerX : int,
centerY : int,
radius : float,
color : uint
) : Unit {
    janus_graphics_draw_circle(centerX, centerY, radius, color)
}

def drawCircleAt(center : Vector2, radius : float, color : Color) : Unit {
    drawCircle(int(center.x), int(center.y), radius, color.packed())
}

def drawRectangle(
x : int,
y : int,
width : int,
height : int,
color : uint
) : Unit {
    janus_graphics_draw_rectangle(x, y, width, height, color)
}

def drawRectangleArea(area : Rectangle, color : Color) : Unit {
    drawRectangle(
    int(area.x),
    int(area.y),
    int(area.width),
    int(area.height),
    color.packed()
    )
}

def drawText(
text : string,
x : int,
y : int,
fontSize : int,
color : uint
) : Unit {
    janus_graphics_draw_text(cstr(text), x, y, fontSize, color)
}

def drawTextAt(
text : string,
position : Vector2,
fontSize : int,
color : Color
) : Unit {
    drawText(
    text,
    int(position.x),
    int(position.y),
    fontSize,
    color.packed()
    )
}

def loadTexture(fileName : string) : Texture {
    return new Texture(janus_graphics_load_texture(cstr(fileName)))
}

def loadFont(fileName : string, fontSize : int) : Font {
    return new Font(janus_graphics_load_font(cstr(fileName), fontSize))
}

def initAudio() : bool {
    return janus_graphics_init_audio()
}

def closeAudio() : Unit {
    janus_graphics_close_audio()
}

def setMasterVolume(volume : float) : Unit {
    janus_graphics_set_master_volume(volume)
}

def loadSound(fileName : string) : Sound {
    return new Sound(janus_graphics_load_sound(cstr(fileName)))
}

def loadMusic(fileName : string) : Music {
    return new Music(janus_graphics_load_music(cstr(fileName)))
}

def isKeyDown(key : Key) : bool {
    return janus_graphics_is_key_down(int(key))
}

def isKeyPressed(key : Key) : bool {
    return janus_graphics_is_key_pressed(int(key))
}

def keyPressed() : int {
    return janus_graphics_key_pressed()
}

def mouseX() : int {
    return janus_graphics_mouse_x()
}

def mouseY() : int {
    return janus_graphics_mouse_y()
}

def setMousePosition(x : int, y : int) : Unit {
    janus_graphics_set_mouse_position(x, y)
}

def mouseWheelMove() : float {
    return janus_graphics_mouse_wheel_move()
}

def isMouseButtonDown(button : MouseButton) : bool {
    return janus_graphics_is_mouse_button_down(int(button))
}

def isMouseButtonPressed(button : MouseButton) : bool {
    return janus_graphics_is_mouse_button_pressed(int(button))
}

def showCursor() : Unit {
    janus_graphics_show_cursor()
}

def hideCursor() : Unit {
    janus_graphics_hide_cursor()
}

def isCursorHidden() : bool {
    return janus_graphics_is_cursor_hidden()
}

def enableCursor() : Unit {
    janus_graphics_enable_cursor()
}

def disableCursor() : Unit {
    janus_graphics_disable_cursor()
}

def isGamepadAvailable(gamepad : int) : bool {
    return janus_graphics_is_gamepad_available(gamepad)
}

def gamepadName(gamepad : int) : Ptr[byte] {
    return janus_graphics_gamepad_name(gamepad)
}

def isGamepadButtonDown(gamepad : int, button : GamepadButton) : bool {
    return janus_graphics_is_gamepad_button_down(gamepad, int(button))
}

def isGamepadButtonPressed(gamepad : int, button : GamepadButton) : bool {
    return janus_graphics_is_gamepad_button_pressed(gamepad, int(button))
}

def isGamepadButtonReleased(gamepad : int, button : GamepadButton) : bool {
    return janus_graphics_is_gamepad_button_released(gamepad, int(button))
}

def gamepadButtonPressed() : int {
    return janus_graphics_gamepad_button_pressed()
}

def gamepadAxisCount(gamepad : int) : int {
    return janus_graphics_gamepad_axis_count(gamepad)
}

def gamepadAxis(gamepad : int, axis : GamepadAxis) : float {
    return janus_graphics_gamepad_axis(gamepad, int(axis))
}

def setGamepadVibration(
gamepad : int,
leftMotor : float,
rightMotor : float,
duration : float
) : Unit {
    janus_graphics_set_gamepad_vibration(
    gamepad,
    leftMotor,
    rightMotor,
    duration
    )
}
