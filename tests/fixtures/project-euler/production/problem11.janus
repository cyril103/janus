def product_at(grid : Array[int], row : usize, col : usize, row_step : int, col_step : int) : int {
    val width : usize = usize(20)
    var product : int = 1
    var offset : int = 0
    while offset < 4 {
        val current_row : usize = usize(int(row) + row_step * offset)
        val current_col : usize = usize(int(col) + col_step * offset)
        product = product * grid.get(current_row * width + current_col)
        offset = offset + 1
    }
    return product
}

def solve() : int {
    val grid : Array[int] = build_grid()
    defer delete grid
    val size : usize = usize(20)
    var best : int = 0
    var row : usize = usize(0)
    while row < size {
        var col : usize = usize(0)
        while col < size {
            if col + usize(3) < size {
                val right : int = product_at(grid, row, col, 0, 1)
                if right > best { best = right }
            }
            if row + usize(3) < size {
                val down : int = product_at(grid, row, col, 1, 0)
                if down > best { best = down }
            }
            if row + usize(3) < size && col + usize(3) < size {
                val diag_down : int = product_at(grid, row, col, 1, 1)
                if diag_down > best { best = diag_down }
            }
            if row >= usize(3) && col + usize(3) < size {
                val diag_up : int = product_at(grid, row, col, -1, 1)
                if diag_up > best { best = diag_up }
            }
            col = col + usize(1)
        }
        row = row + usize(1)
    }
    return best
}

def main() : int {
    println(solve())
    return 0
}
