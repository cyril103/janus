def is_prime(candidate : int) : bool {
    if candidate < 2 {
        return false
    }
    if candidate == 2 {
        return true
    }
    if candidate % 2 == 0 {
        return false
    }
    var divisor : int = 3
    while divisor * divisor <= candidate {
        if candidate % divisor == 0 {
            return false
        }
        divisor = divisor + 2
    }
    return true
}

def solve() : double {
    var sum : double = 0.0
    var candidate : int = 2
    while candidate < 2000000 {
        if is_prime(candidate) {
            sum = sum + double(candidate)
        }
        candidate = candidate + 1
    }
    return sum
}

def main() : int {
    println(solve())
    return 0
}
