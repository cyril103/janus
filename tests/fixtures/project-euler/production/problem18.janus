def index_for(row : usize, col : usize) : usize {
    return row * (row + usize(1)) / usize(2) + col
}

def solve() : int {
    val values : Array[int] = build_triangle()
    defer delete values
    var row : usize = usize(13)
    while row < usize(15) {
        var col : usize = usize(0)
        while col <= row {
            val left : int = values.get(index_for(row + usize(1), col))
            val right : int = values.get(index_for(row + usize(1), col + usize(1)))
            val child : int = if left > right { left } else { right }
            val current : usize = index_for(row, col)
            values.set(current, values.get(current) + child)
            col = col + usize(1)
        }
        if row == usize(0) {
            break
        }
        row = row - usize(1)
    }
    return values.get(usize(0))
}

def main() : int {
    println(solve())
    return 0
}
