def solve() : double {
    val digits : Array[int] = build_digits()
    defer delete digits
    val window : usize = usize(13)
    var best : double = 0.0
    var start : usize = usize(0)
    while start + window <= digits.size() {
        var product : double = 1.0
        var index : usize = usize(0)
        while index < window {
            product = product * double(digits.get(start + index))
            index = index + usize(1)
        }
        if product > best {
            best = product
        }
        start = start + usize(1)
    }
    return best
}

def main() : int {
    println(solve())
    return 0
}
