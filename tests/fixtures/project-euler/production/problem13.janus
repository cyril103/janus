def solve() : double {
    val values : Array[int] = build_digits()
    defer delete values
    val numbers : usize = usize(100)
    val width : usize = usize(50)
    val digits : Array[int] = new Array[int](usize(60))
    var carry : int = 0
    var column : usize = width
    while column > usize(0) {
        var sum : int = carry
        var row : usize = usize(0)
        while row < numbers {
            sum = sum + values.get(row * width + column - usize(1))
            row = row + usize(1)
        }
        digits.push(sum % 10)
        carry = sum / 10
        column = column - usize(1)
    }
    while carry > 0 {
        digits.push(carry % 10)
        carry = carry / 10
    }
    var answer : double = 0.0
    var used : usize = usize(0)
    var index : usize = digits.size()
    while used < usize(10) {
        index = index - usize(1)
        answer = answer * 10.0 + double(digits.get(index))
        used = used + usize(1)
    }
    delete digits
    return answer
}

def main() : int {
    println(solve())
    return 0
}
