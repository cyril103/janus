def is_palindrome(value : int) : bool {
    var current : int = value
    var reversed : int = 0
    while current > 0 {
        reversed = reversed * 10 + current % 10
        current = current / 10
    }
    return value == reversed
}

def solve() : int {
    var best : int = 0
    var left : int = 999
    while left >= 100 {
        // Once the largest product for this left factor cannot beat the best
        // palindrome, every smaller left factor is also bounded by the same cap.
        if left * 999 <= best {
            break
        }

        var right : int = 999
        while right >= left {
            val product : int = left * right
            // Products shrink as right descends, so the rest of this inner loop
            // cannot improve the answer once this bound is reached.
            if product <= best {
                break
            }
            if is_palindrome(product) {
                best = product
            }
            right = right - 1
        }
        left = left - 1
    }
    return best
}

def main() : int {
    println(solve())
    return 0
}
