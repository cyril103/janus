def is_palindrome(value : int) : bool {
    var current : int = value
    var reversed : int = 0
    while current > 0 {
        reversed = reversed * 10 + current % 10
        current = current / 10
    }
    return value == reversed
}

def solve() : int {
    var best : int = 0
    var left : int = 999
    while left >= 100 {
        var right : int = left
        while right >= 100 {
            val product : int = left * right
            if product > best && is_palindrome(product) {
                best = product
            }
            right = right - 1
        }
        left = left - 1
    }
    return best
}

def main() : int {
    println(solve())
    return 0
}
