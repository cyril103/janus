def solve() : int {
    var a : int = 1
    while a < 1000 {
        var b : int = a + 1
        while b < 1000 {
            val c : int = 1000 - a - b
            if c > b && a * a + b * b == c * c {
                return a * b * c
            }
            b = b + 1
        }
        a = a + 1
    }
    return 0
}

def main() : int {
    println(solve())
    return 0
}
