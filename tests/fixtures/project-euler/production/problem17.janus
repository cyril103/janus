def under_twenty(value : int) : int {
    if value == 0 {
        return 0
    }
    if value == 1 || value == 2 || value == 6 || value == 10 {
        return 3
    }
    if value == 4 || value == 5 || value == 9 {
        return 4
    }
    if value == 3 || value == 7 || value == 8 {
        return 5
    }
    if value == 11 || value == 12 {
        return 6
    }
    if value == 15 || value == 16 {
        return 7
    }
    if value == 13 || value == 14 || value == 18 || value == 19 {
        return 8
    }
    return 9
}

def tens_word(value : int) : int {
    if value == 2 || value == 3 || value == 8 || value == 9 {
        return 6
    }
    if value == 4 || value == 5 || value == 6 {
        return 5
    }
    return 7
}

def letters(value : int) : int {
    if value < 20 {
        return under_twenty(value)
    }
    if value < 100 {
        return tens_word(value / 10) + under_twenty(value % 10)
    }
    if value < 1000 {
        val rest : int = value % 100
        val base : int = under_twenty(value / 100) + 7
        if rest == 0 {
            return base
        }
        return base + 3 + letters(rest)
    }
    return 11
}

def solve() : int {
    var total : int = 0
    var value : int = 1
    while value <= 1000 {
        total = total + letters(value)
        value = value + 1
    }
    return total
}

def main() : int {
    println(solve())
    return 0
}
