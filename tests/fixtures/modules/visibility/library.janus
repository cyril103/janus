module visibility.library

private struct Secret(val value : int) {}

private def secretValue() : int {
    val secret : Secret = new Secret(41)
    return secret.value
}

class ModuleCounter(internal var value : int) {
    internal def increment() : int {
        value = value + 1
        return value
    }
}

def publicValue() : int {
    val counter : ModuleCounter = new ModuleCounter(secretValue())
    val result : int = counter.increment() + counter.value
    delete counter
    return result
}
