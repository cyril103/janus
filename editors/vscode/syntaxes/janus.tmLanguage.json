{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Janus",
  "scopeName": "source.janus",
  "patterns": [
    {
      "name": "comment.line.double-slash.janus",
      "match": "//.*$"
    },
    {
      "name": "keyword.control.janus",
      "match": "\\b(if|else|match|for|in|while|break|continue|return|defer|delete|move|consume)\\b"
    },
    {
      "name": "storage.type.janus",
      "match": "\\b(class|trait|enum|def|val|var|private|extern|module|import|extends|new|destructor)\\b"
    },
    {
      "name": "support.type.primitive.janus",
      "match": "\\b(int|double|byte|char|bool|string|unit|usize)\\b"
    },
    {
      "name": "constant.language.janus",
      "match": "\\b(true|false)\\b"
    },
    {
      "name": "string.quoted.double.janus",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.janus",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "constant.numeric.janus",
      "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
    }
  ]
}
